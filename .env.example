# ------------------------------------------------------------------
# Relay configuration. Copy to .env and adjust for your environment.
#   cp deployment/.env.example deployment/.env
# On a VPS: change every password/secret below. Production compose rejects missing values,
# and the backend rejects weak/default secrets when the prod profile is active.
# ------------------------------------------------------------------

# ---- Public entry (nginx) ----
# Port nginx listens on. The app is reached at http://<host>:${HTTP_PORT}
HTTP_PORT=80

# ---- Postgres ----
POSTGRES_USER=relay
POSTGRES_PASSWORD=relay
POSTGRES_DB=relay

# ---- ClickHouse (analytics) ----
CLICKHOUSE_USER=relay
CLICKHOUSE_PASSWORD=relay
CLICKHOUSE_DB=relay

# ---- Redis ----
# (no auth in the bundled dev config; add one in production)

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=relay
MINIO_ROOT_PASSWORD=relay-secret
RELAY_S3_BUCKET=relay-creatives

# ---- Auth ----
# MUST be changed in production — min 32 chars.
RELAY_AUTH_JWT_SECRET=relay-dev-secret-change-me-0123456789-abcdef

# ---- Admin (Ops console at /admin) ----
# Ensured at startup. CHANGE in production.
RELAY_ADMIN_EMAIL=admin@relay.dev
RELAY_ADMIN_PASSWORD=admin12345

# ---- CORS ----
# Browser origins allowed to call the API directly. Behind nginx the app is same-origin,
# so this only matters for split-origin/dev. Add your domain in production, e.g.:
#   RELAY_CORS_ORIGINS=https://app.yourdomain.com
RELAY_CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080

# ---- Public base URL (used to build email links & OAuth redirects) ----
# Local default matches the Google console's localhost redirect (port 8081).
APP_BASE_URL=http://localhost:8081

# ---- Google OAuth (server-side code flow) ----
# From Google Cloud console. Redirect URI is <APP_BASE_URL>/api/auth/google/callback,
# which must be registered. Leave GOOGLE_REDIRECT_URI empty to derive it from the request host
# (recommended for multi-domain: d0187.in / www / admin).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ---- SMTP (transactional email: verification, etc.) ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ---- SMS OTP (Fast2SMS) ----
# Leave empty only in development. Production fails closed when OTP delivery is unavailable.
FAST2SMS_API_KEY=

# ---- Frontend (build-time) ----
# Leave EMPTY to use same-origin (recommended, works behind nginx).
# Only set if the browser must reach the backend on a different origin.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_BASE_URL=
